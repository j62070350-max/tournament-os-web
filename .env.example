# ── Tournament Bot ─────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_tournament_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id

# ── Mech Arena Bot (Bot #2 — separate token required) ─────────────────────────
MECH_DISCORD_TOKEN=your_mech_arena_bot_token_here

# ── Database ───────────────────────────────────────────────────────────────────
# Plain postgresql:// or postgres:// are auto-converted to asyncpg format.
# Railway, Render, Supabase, Heroku, Neon, etc. all provide this format.
DATABASE_URL=postgresql://user:password@localhost:5432/tournament_os

# ── AI (shared by both bots) ───────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile   # optional override

# ── Web Security ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ADMIN_DASHBOARD_TOKEN=change_me_to_a_long_random_string
SECRET_KEY=change_me_to_another_long_random_string

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=production     # development | production
WEB_HOST=0.0.0.0
WEB_PORT=8000              # ignored when PORT is set (Railway injects PORT automatically)
LOG_LEVEL=INFO

# ── Mech Arena Bot — Knowledge Base ───────────────────────────────────────────
# Path to the knowledge directory (default: knowledge)
# KNOWLEDGE_DIR=knowledge
